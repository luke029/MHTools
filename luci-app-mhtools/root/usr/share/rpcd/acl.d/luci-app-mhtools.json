{
	"luci-app-mhtools": {
		"description": "Grant access to LuCI MHTools procedures",
		"read": {
			"ubus": {
				"luci.mhtools": [
					"status",
					"version",
					"list_profiles",
					"validate_profile",
					"get_dashboard_url",
					"get_all_logs",
					"clear_logs",
					"get_profile_content",
					"get_app_info"
				]
			},
			"uci": [
				"mhtools"
			],
			"file": {
				"/etc/mhtools/profiles/*": [
					"list",
					"read"
				],
				"/etc/mhtools/run/*": [
					"list",
					"read"
				],
				"/var/log/mhtools/*": [
					"read"
				]
			}
		},
		"write": {
			"ubus": {
				"luci.mhtools": [
					"status",
					"restart",
					"start",
					"stop",
					"set_enabled",
					"version",
					"list_profiles",
					"validate_profile",
					"upload_profile",
					"delete_profile",
					"select_profile",
					"reset",
					"get_dashboard_url",
					"get_all_logs",
					"clear_logs",
					"get_profile_content",
					"save_profile_content",
					"get_app_info",
					"upgrade_app"
				]
			},
			"uci": [
				"mhtools"
			],
			"file": {
				"/etc/mhtools/profiles/*": [
					"write"
				],
				"/etc/mhtools/run/*": [
					"write"
				],
				"/var/log/mhtools/*": [
					"write"
				]
			}
		}
	}
}
